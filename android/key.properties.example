# Copy to android/key.properties and fill in your local signing values.
# Do not commit android/key.properties or keystore files.

# --- Play Store (Google Play) ---
playstore.storeFile=../release-keys/erebrus-vpn-playstore.jks
playstore.storePassword=<playstore-keystore-password>
playstore.keyAlias=erebrus-vpn-playstore
playstore.keyPassword=<playstore-key-password>

# --- dApp Store (Solana) ---
# Must be a separate keystore from Play Store.
dappstore.storeFile=../release-keys/erebrus-vpn-dappstore.jks
dappstore.storePassword=<dappstore-keystore-password>
dappstore.keyAlias=erebrus-vpn-dappstore
dappstore.keyPassword=<dappstore-key-password>