# Copy to .env for local dev (gitignored). CI copies this file before analyze/build.
REOWN_PROJECT_ID=
EREBRUS_WEB_ORIGIN=
GATEWAY_URL=

# Optional native social login (non-Solana-mobile devices). Unset => the
# Google/Apple buttons stay hidden (no native call, no errors). Requires the
# matching audience in the gateway's GOOGLE_CLIENT_IDS/APPLE_CLIENT_IDS.
GOOGLE_SERVER_CLIENT_ID=
APPLE_SERVICE_ID=
APPLE_REDIRECT_URI=