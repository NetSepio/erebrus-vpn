# Copy to .env (gitignored). Format: KEY=value per line — no quotes.
# Run: flutter run -d macos --dart-define-from-file=.env

REOWN_PROJECT_ID=your_reown_project_id_from_cloud.reown.com

# Local webapp (pnpm dev in erebrus-webapp):
EREBRUS_WEB_ORIGIN=http://localhost:3000

# Dev deploy:
# EREBRUS_WEB_ORIGIN=https://dev.erebrus.io